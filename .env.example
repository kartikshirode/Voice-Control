# Copy to .env and fill in values. Never commit .env.

# --- LLM providers ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Local LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=qwen3:4b

# --- Budget caps (Gemini free-tier defaults; override for paid) ---
GEMINI_RPD_LIMIT=250
GEMINI_BUDGET_ALERT_PERCENT=80
GEMINI_BUDGET_FALLBACK_PERCENT=95

# --- Privacy gate ---
PRIVACY_GATE_THRESHOLD=0.7

# --- Server ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8765

# --- Optional ---
ELEVENLABS_API_KEY=
